<Window x:Class="Winui3_Wpf_XamlNexus.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Winui3_Wpf_XamlNexus"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
    xmlns:lang="clr-namespace:Winui3_Wpf_XamlNexus.Lang"        
    Loaded="Window_Loaded"
    Closing="Window_Closing"
    SourceInitialized="Window_SourceInitialized"
    ShowInTaskbar="False"
    Left="-99999"
    WindowStartupLocation="Manual"
    Visibility="Hidden"
    mc:Ignorable="d"
    Title="TrayIconWindow" Height="450" Width="800">

    <Grid>
        <tray:NotifyIcon x:Name="notifyIcon"
            FocusOnLeftClick="True"
            Icon="pack://application:,,,/xamlnexus.ico"
            MenuOnRightClick="True"
            LeftDoubleClick="NotifyIcon_LeftDoubleClick"
            TooltipText="Winui3_Wpf_XamlNexus">
            <tray:NotifyIcon.Menu>
                <ContextMenu>
                    <MenuItem MinWidth="200" Click="OpenAppMenuItem_Click">
                        <MenuItem.Icon>
                            <ui:SymbolIcon 
                                Height="25"
                                Width="25"
                                Symbol="WindowAd20"/>
                        </MenuItem.Icon>
                        <MenuItem.Header>
                            <TextBlock 
                                Text="{Binding [Systray_TextOpenApp], Source={x:Static lang:LanguageManager.Instance}}"
                                FontSize="14"
                                VerticalAlignment="Center"/>
                        </MenuItem.Header>
                    </MenuItem>

                    <Separator/>

                    <MenuItem MinWidth="200" Click="ExitMenuItem_Click">
                        <MenuItem.Icon>
                            <ui:SymbolIcon 
                                Height="25"
                                Width="25"
                                Symbol="ArrowExit20" />
                        </MenuItem.Icon>
                        <MenuItem.Header>
                            <TextBlock 
                                Text="{Binding [Systray_TextExit], Source={x:Static lang:LanguageManager.Instance}}"
                                FontSize="14"
                                VerticalAlignment="Center"/>
                        </MenuItem.Header>
                    </MenuItem>
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>
    </Grid>
</Window>
